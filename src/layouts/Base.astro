---
import '../styles/global.css';
import { Font } from 'astro:assets';
import IconSprite from '../components/IconSprite.astro';
import faviconUrl from '../assets/logos/mark-light-bg.webp?url';

interface Props {
  title: string;
  description: string;
  screenLabel?: string;
}
const { title, description, screenLabel = 'Home' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/webp" href={faviconUrl} />
    <Font cssVariable="--font-display" preload={[{ weight: 400 }]} />
    <Font cssVariable="--font-body" preload={[{ weight: 400 }]} />
    <script is:inline>
      // Apply the saved or system theme before paint to avoid a flash.
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'dark' || (!stored && systemDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body data-screen-label={screenLabel}>
    <IconSprite />
    <slot />
  </body>
</html>
