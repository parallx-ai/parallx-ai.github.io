---
import { Image } from 'astro:assets';

interface Person {
  name: string;
  role: string;
  bio: string;
  slug: string;
  website?: string;
  twitter?: string;
  linkedin?: string;
  huggingface?: string;
  github?: string;
  google_scholar?: string;
}
interface Props {
  person: Person;
  /** Position in a 5-person trustee row — drives responsive col-spans. */
  index?: number;
}
const { person, index = 0 } = Astro.props;

// Photo assets are bundled and optimised by Astro at build time. Glob-import
// every WebP source under src/assets/people/ and look up by slug — this lets
// people.json stay as data while astro:assets handles resizing, modern-format
// negotiation, and `srcset` generation.
const photos = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/people/*.webp',
  { eager: true },
);
const photo = photos[`../assets/people/${person.slug}.webp`]?.default;
if (!photo) {
  throw new Error(
    `Missing photo for "${person.slug}" — add src/assets/people/${person.slug}.webp`,
  );
}

// Trustee row at <=1000px (6-col grid): first 2 span 3, rest span 2.
// At <=600px collapses to a single column.
const span = index < 2 ? 'max-nav:col-span-3' : 'max-nav:col-span-2';

// Per-person framing tweaks for the circular crop. The default anchors at
// `center 25%` (face roughly at viewport centre for typical headshots); some
// photos need a different anchor, and Yonatan's needs an extra zoom too.
function getZoom(name: string): string {
  const lower = name.toLowerCase();
  if (lower.includes('yonatan'))
    return 'scale-[1.50] origin-[center_10%]';
  if (lower.includes('mario') || lower.includes('seraphina'))
    return 'object-[center_65%] scale-[1.2]';
  return 'object-[center_25%]';
}
const zoom = getZoom(person.name);

// Social links, in display order. Only populated ones are rendered.
const socials = (
  [
    { key: 'website', label: 'Website' },
    { key: 'google_scholar', label: 'Google Scholar' },
    { key: 'twitter', label: 'X / Twitter' },
    { key: 'linkedin', label: 'LinkedIn' },
    { key: 'github', label: 'GitHub' },
    { key: 'huggingface', label: 'Hugging Face' },
  ] as const
)
  .map((s) => ({ ...s, url: person[s.key] }))
  .filter((s): s is typeof s & { url: string } => !!s.url);
---
<div
  class:list={[
    'group flex w-full max-w-[240px] flex-col gap-2.5',
    span,
    'max-xs:col-span-1 max-xs:last:col-span-2 max-xs:max-w-[200px] max-xs:text-center',
  ]}
>
  <div class="relative mx-auto aspect-square w-full max-w-[160px] overflow-hidden rounded-full border border-rule-soft bg-paper max-xs:max-w-[110px]">
    <Image
      src={photo}
      alt={person.name}
      width={640}
      quality={90}
      loading="lazy"
      class:list={[
        'absolute inset-0 h-full w-full object-cover [filter:saturate(0.85)_contrast(0.98)] transition-[filter] group-hover:[filter:saturate(1)_contrast(1)]',
        zoom,
      ]}
    />
  </div>
  <div class="mt-1.5 font-display text-[18px] leading-[1.2] tracking-[-0.01em]">
    {person.website ? (
      <a
        href={person.website}
        rel="noopener"
        target="_blank"
        class="underline decoration-rule decoration-1 underline-offset-4 transition-colors hover:text-gold-deep hover:decoration-gold"
      >
        {person.name}
      </a>
    ) : (
      person.name
    )}
  </div>
  <div class="font-mono text-[10.5px] uppercase tracking-[0.08em] text-ink-2">{person.role}</div>
  <div class="text-[12.5px] text-ink-1">{person.bio}</div>

  {
    socials.length > 0 && (
      <div class="mt-0.5 flex flex-wrap items-center gap-2.5 max-xs:justify-center">
        {socials.map((s) => (
          <a
            href={s.url}
            rel="noopener"
            target="_blank"
            aria-label={`${person.name} — ${s.label}`}
            title={s.label}
            class="text-ink-3 transition-colors hover:text-gold-deep"
          >
            <svg
              class={s.key === 'twitter' ? 'h-[15px] w-[15px]' : 'h-[17px] w-[17px]'}
              aria-hidden="true"
            >
              <use href={`#icon-${s.key}`} />
            </svg>
          </a>
        ))}
      </div>
    )
  }
</div>
